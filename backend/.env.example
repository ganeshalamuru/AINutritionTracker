# Environment variables for the backend. Copy to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is gitignored — never commit real keys. API keys can also be set at
# runtime from the in-app Settings page (stored in the local DB), in which case
# they don't need to live here.

# --- Vision / LLM providers -------------------------------------------------
# Groq is the default provider for meal analysis; Gemini is the fallback.
GROQ_API_KEY=
GEMINI_API_KEY=

# Skip real vision calls and return canned analysis output (dev/testing only).
# Leave empty/unset in normal use; set to 1 to enable.
MOCK_GEMINI=

# Local Ollama vision host (only used when the vision provider is set to Ollama).
OLLAMA_HOST=http://localhost:11434

# --- Nutrition data ---------------------------------------------------------
# USDA FoodData Central API key (live-API mode only; the offline index needs none).
USDA_API_KEY=

# --- Runtime / deployment ---------------------------------------------------
# development | production. Setting `production` disables /docs, /redoc, /scalar,
# /openapi.json AND the dev-only /api/admin/* data-inspection routes.
APP_ENV=development

# Comma-separated list of allowed CORS origins. Empty = CORS off (same-origin only),
# which is correct for the default same-origin deployment. Only set this if a
# separate front-end origin must call the API cross-origin.
CORS_ORIGINS=

# Prometheus /metrics endpoint. 1 = on (default), 0 = off.
METRICS_ENABLED=1

# --- Error tracking (optional) ----------------------------------------------
# Sentry is initialized only when SENTRY_DSN is set; leave empty to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
